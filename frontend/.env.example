# --- Supabase ---
# Récupère ces valeurs dans : https://app.supabase.com → ton projet → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# --- Stripe (côté public) ---
# Récupère ta clé publishable dans : https://dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Landing : vidéo hero (optionnel) ---
# URL d'une vidéo MP4/WebM hébergée publiquement (CDN, Mux, Cloudflare Stream…).
# Si la variable est vide, la landing affiche un mockup animé du dashboard.
VITE_HERO_VIDEO_URL=
