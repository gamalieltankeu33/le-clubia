# =====================================================================
# Variables d'env pour les Edge Functions Supabase et l'admin local
# Ces valeurs ne doivent JAMAIS être versionnées (.env est dans .gitignore)
# =====================================================================

# --- Supabase (côté serveur) ---
# Service role key : Settings → API → "service_role" (secret !)
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_ANON_KEY=eyJhbGci...

# --- Paiement Chariow ---
# Chariow est la passerelle de paiement utilisée pour les abonnements.
# La clé API privée se génère depuis le dashboard Chariow :
# Doc : https://chariow.dev
CHARIOW_API_KEY=sk_test_...

# Identifiants publics ou slugs des produits Chariow correspondant aux plans
# d'abonnement Le Club IA. À récupérer dans Chariow :
CHARIOW_PRODUCT_ID_TRIAL=prd_xxxx
CHARIOW_PRODUCT_ID_TRIMESTRIAL=prd_xxxx
CHARIOW_PRODUCT_ID_SEMESTRIAL=prd_xxxx
CHARIOW_PRODUCT_ID_ANNUAL=prd_xxxx

# --- URLs de redirection après checkout / portal ---
APP_URL=http://localhost:5173

# --- Resend (emails) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Le Club IA <hello@leclubia.com>"

# --- Anthropic (Coach IA) ---
# https://console.anthropic.com → Settings → API Keys
# À configurer en SECRET côté Supabase Edge Functions, pas en .env local :
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...
