# =====================================================================
# Variables d'env pour les Edge Functions Supabase et l'admin local
# Ces valeurs ne doivent JAMAIS être versionnées (.env est dans .gitignore)
# =====================================================================

# --- Supabase (côté serveur) ---
# Service role key : Settings → API → "service_role" (secret !)
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_ANON_KEY=eyJhbGci...

# --- Paiement (placeholder Stripe, sera remplacé par mobile money) ---
# Le projet a pivoté vers un abonnement annuel à 69 000 FCFA/an payé par
# mobile money africain (Orange Money, Wave, MTN Money, Moov Money).
# Les variables Stripe ci-dessous sont conservées comme placeholder en
# attendant le choix définitif du partenaire mobile money.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_...

# Quand l'API mobile money sera intégrée, on ajoutera ici :
# MOBILE_MONEY_PROVIDER_API_KEY=...
# MOBILE_MONEY_WEBHOOK_SECRET=...

# --- URLs de redirection après checkout / portal ---
APP_URL=http://localhost:5173

# --- Resend (emails) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Le Club IA <hello@leclubia.com>"

# --- Anthropic (Coach IA) ---
# https://console.anthropic.com → Settings → API Keys
# À configurer en SECRET côté Supabase Edge Functions, pas en .env local :
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...
