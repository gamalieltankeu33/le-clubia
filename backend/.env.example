# =====================================================================
# Variables d'env pour les Edge Functions Supabase et l'admin local
# Ces valeurs ne doivent JAMAIS être versionnées (.env est dans .gitignore)
# =====================================================================

# --- Supabase (côté serveur) ---
# Service role key : Settings → API → "service_role" (secret !)
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_ANON_KEY=eyJhbGci...

# --- Paiement Maketou (Mobile Money Afrique) ---
# Maketou est la passerelle Mobile Money (Orange Money, Wave, MTN,
# Moov) utilisée pour les abonnements. La clé API est liée à une
# BOUTIQUE (pas à un compte) — la générer depuis le dashboard Maketou :
#   Boutique → Autres → Clés API → Ajouter une clé API
# Doc : https://api.maketou.net
MAKETOU_API_KEY=mkt_...

# Identifiants publics des produits Maketou correspondant aux 2 plans
# d'abonnement Le Club IA. À récupérer dans Maketou :
#   Boutique → Produit → Partager → Identifiant public du produit
# (un produit par plan, l'API ne supporte qu'un produit par panier).
MAKETOU_PRODUCT_ID_ANNUAL=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MAKETOU_PRODUCT_ID_SEMESTRIAL=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- URLs de redirection après checkout / portal ---
APP_URL=http://localhost:5173

# --- Resend (emails) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Le Club IA <hello@leclubia.com>"

# --- Anthropic (Coach IA) ---
# https://console.anthropic.com → Settings → API Keys
# À configurer en SECRET côté Supabase Edge Functions, pas en .env local :
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...
